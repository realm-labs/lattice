{
  "title": "Lattice cluster discovery and lifecycle",
  "uid": "lattice-cluster-lifecycle",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["lattice", "cluster", "lifecycle"],
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Discovery targets and stale age",
      "targets": [
        {"refId": "A", "expr": "lattice_discovery_targets{cluster=~\"$cluster\"}"},
        {"refId": "B", "expr": "lattice_discovery_stale_seconds{cluster=~\"$cluster\"}"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Bootstrap attempts and rejections",
      "targets": [
        {"refId": "A", "expr": "sum by (result) (rate(lattice_bootstrap_attempts_total{cluster=~\"$cluster\"}[5m]))"},
        {"refId": "B", "expr": "sum by (reason) (rate(lattice_bootstrap_rejections_total{cluster=~\"$cluster\"}[5m]))"}
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Lifecycle states",
      "targets": [
        {"refId": "A", "expr": "sum by (state) (lattice_member_lifecycle_state{cluster=~\"$cluster\"})"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Join and degraded duration",
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(lattice_join_duration_seconds_bucket{cluster=~\"$cluster\"}[10m])))"},
        {"refId": "B", "expr": "lattice_degraded_duration_seconds{cluster=~\"$cluster\"}"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Reconciliation and snapshot restart",
      "targets": [
        {"refId": "A", "expr": "sum(rate(lattice_reconciliation_total{cluster=~\"$cluster\"}[5m]))"},
        {"refId": "B", "expr": "sum(rate(lattice_snapshot_restarts_total{cluster=~\"$cluster\"}[5m]))"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Drain, removal, and fencing",
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(lattice_drain_duration_seconds_bucket{cluster=~\"$cluster\"}[10m])))"},
        {"refId": "B", "expr": "sum by (reason) (rate(lattice_member_removals_total{cluster=~\"$cluster\"}[5m]))"},
        {"refId": "C", "expr": "sum(rate(lattice_stale_incarnation_rejections_total{cluster=~\"$cluster\"}[5m]))"},
        {"refId": "D", "expr": "sum(rate(lattice_forced_shutdowns_total{cluster=~\"$cluster\"}[5m]))"}
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Placement-domain leaders and sessions",
      "targets": [
        {"refId": "A", "expr": "max by (domain, state) (lattice_domain_leader_term{cluster=~\"$cluster\",domain=~\"$domain\"})"},
        {"refId": "B", "expr": "min by (domain) (lattice_domain_session_ready{cluster=~\"$cluster\",domain=~\"$domain\"})"},
        {"refId": "C", "expr": "lattice_domain_leader_concentration_max{cluster=~\"$cluster\"}"}
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Domain route availability and unresolved requests",
      "targets": [
        {"refId": "A", "expr": "min by (domain) (lattice_domain_route_available{cluster=~\"$cluster\",domain=~\"$domain\"})"},
        {"refId": "B", "expr": "sum by (domain) (lattice_domain_unresolved_requests{cluster=~\"$cluster\",domain=~\"$domain\"})"}
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Domain membership, capacity, and load",
      "targets": [
        {"refId": "A", "expr": "sum by (domain) (lattice_domain_members{cluster=~\"$cluster\",domain=~\"$domain\"})"},
        {"refId": "B", "expr": "sum by (domain) (lattice_domain_capacity_units{cluster=~\"$cluster\",domain=~\"$domain\"})"},
        {"refId": "C", "expr": "sum by (domain) (lattice_domain_load_units{cluster=~\"$cluster\",domain=~\"$domain\"})"}
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Domain authority and reconciliation",
      "targets": [
        {"refId": "A", "expr": "sum by (domain) (lattice_domain_slots{cluster=~\"$cluster\",domain=~\"$domain\"})"},
        {"refId": "B", "expr": "sum by (domain) (lattice_domain_claims{cluster=~\"$cluster\",domain=~\"$domain\"})"},
        {"refId": "C", "expr": "sum by (domain) (lattice_domain_plans{cluster=~\"$cluster\",domain=~\"$domain\"})"},
        {"refId": "D", "expr": "max by (domain) (lattice_domain_reconciliation_backlog{cluster=~\"$cluster\",domain=~\"$domain\"})"},
        {"refId": "E", "expr": "max by (domain) (lattice_domain_reconciliation_oldest_millis{cluster=~\"$cluster\",domain=~\"$domain\"})"}
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Cross-domain drain progress",
      "targets": [
        {"refId": "A", "expr": "max by (domain, state) (lattice_domain_drain_remaining_authorities{cluster=~\"$cluster\",domain=~\"$domain\"})"}
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "query": "label_values(lattice_member_lifecycle_state, cluster)",
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "domain",
        "type": "query",
        "query": "label_values(lattice_domain_leader_term{cluster=~\"$cluster\"}, domain)",
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  }
}
